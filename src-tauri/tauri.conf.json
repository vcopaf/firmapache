{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniFirmador",
  "version": "0.1.0",
  "identifier": "bo.gob.agetic.minifirmador",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MiniFirmador",
        "width": 1024,
        "height": 760,
        "minWidth": 780,
        "minHeight": 600,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
